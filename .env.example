# Azure AI Foundry — Myanmar Astrology AI Reading
# Copy this file to .env and fill in your values

# Azure AI Foundry project endpoint
# e.g. https://your-project.openai.azure.com
VITE_FOUNDRY_ENDPOINT=

# Azure AI Foundry API key
VITE_FOUNDRY_KEY=

# Deployed model name (default: gpt-4o)
VITE_FOUNDRY_MODEL=gpt-4o
